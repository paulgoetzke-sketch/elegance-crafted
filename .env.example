# Wesenberg Schmuck — Umgebungsvariablen (Vorlage)
# Kopiere diese Datei zu `.env` und trage die echten Werte ein.
# `.env` ist in .gitignore und wird NIE committet.

# === Claude / Anthropic API ===
# Nur relevant, sobald serverseitige Claude-Aufrufe erfolgen.
ANTHROPIC_API_KEY=

# === Google Reviews (optional) ===
# Für die GoogleReviews-Komponente, falls Live-Daten eingebunden werden.
VITE_GOOGLE_PLACES_API_KEY=
VITE_GOOGLE_PLACE_ID=

# === Kontaktformular (optional) ===
# Falls das Kontaktformular über einen Mail-Service (z. B. Resend) läuft.
RESEND_API_KEY=
CONTACT_FORM_RECIPIENT=

# Hinweis: Alle mit `VITE_` präfixten Variablen werden in den Client-Bundle
# eingebaut — dort also NIEMALS geheime Server-Keys ablegen.
